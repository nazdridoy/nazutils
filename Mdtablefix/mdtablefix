#!/usr/bin/env python3
"""
mdtablefix
================================
Checks markdown (.md) files for table headers that do not have
an empty line preceding them, and optionally fixes them.

Run  ./mdtablefix --help  for full usage.
"""

import argparse
import os
import re
import sys

VERSION = "1.0.0"

# Regex to match markdown table delimiter rows, e.g. |---| or | :--- | :---: | etc.
DELIMITER_PATTERN = re.compile(r'^\s*\|(?:\s*[:-]+\s*\|)+\s*$')

# ANSI escape codes for coloring terminal output
class Colors:
    HEADER = '\033[95m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    RED = '\033[91m'
    RESET = '\033[0m'
    BOLD = '\033[1m'
    DIM = '\033[2m'

# Detect if terminal supports color
USE_COLOR = sys.stdout.isatty() and os.name != 'nt'
if 'NO_COLOR' in os.environ or os.environ.get('TERM') == 'dumb':
    USE_COLOR = False

def color(text, color_code):
    if USE_COLOR:
        return f"{color_code}{text}{Colors.RESET}"
    return text

def print_issue(filepath, line_num, prev_line_content, header_line_content, dry_run=True):
    rel_path = os.path.relpath(filepath)
    tag = color(" DRY-RUN ", Colors.YELLOW + Colors.BOLD) if dry_run else color(" APPLYING ", Colors.GREEN + Colors.BOLD)
    print(f"{color('●', Colors.YELLOW if dry_run else Colors.GREEN)} {tag} {color(rel_path, Colors.BOLD)}:{color(str(line_num), Colors.CYAN)}")
    # Print a mini diff showing the lack of blank line
    print(f"    {color(f'{line_num-1:4d} |', Colors.DIM)} {prev_line_content}")
    print(f"    {color('     +', Colors.GREEN + Colors.BOLD)} {color('[Insert blank line]', Colors.GREEN + Colors.DIM)}")
    print(f"    {color(f'{line_num:4d} |', Colors.CYAN + Colors.BOLD)} {header_line_content}")
    print()

def process_file(filepath, dry_run=True):
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            content = f.read()
    except Exception as e:
        print(f"{color('ERROR', Colors.RED + Colors.BOLD)} Reading {filepath}: {e}")
        return False

    lines = content.splitlines()
    new_lines = []
    in_code_block = False
    modified = False
    
    i = 0
    while i < len(lines):
        line = lines[i]
        
        # Track code blocks to avoid modifying tables inside code snippets
        if line.strip().startswith('```'):
            in_code_block = not in_code_block
            new_lines.append(line)
            i += 1
            continue
            
        if in_code_block:
            new_lines.append(line)
            i += 1
            continue
            
        # Check if the next line is a table delimiter
        # (meaning the current line 'line' is the table header)
        is_header = False
        if i + 1 < len(lines):
            next_line = lines[i + 1]
            if DELIMITER_PATTERN.match(next_line):
                is_header = True
                
        if is_header:
            # We need an empty/blank line before the table header.
            # Check the last processed line.
            if len(new_lines) > 0:
                prev_line = new_lines[-1]
                if prev_line.strip() != "":
                    # The line before the header is not empty. We insert a blank line.
                    print_issue(filepath, i + 1, prev_line, line, dry_run=dry_run)
                    new_lines.append("")
                    modified = True
            
        new_lines.append(line)
        i += 1

    if modified and not dry_run:
        try:
            with open(filepath, 'w', encoding='utf-8') as f:
                f.write("\n".join(new_lines) + "\n")
        except Exception as e:
            print(f"{color('ERROR', Colors.RED + Colors.BOLD)} Writing {filepath}: {e}")
            
    return modified

def main():
    parser = argparse.ArgumentParser(
        description="Check markdown (.md) files for table headers that do not have an empty line preceding them, and optionally fix them.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
EXAMPLES:
  # Perform a dry-run check of the current directory and all subdirectories
  ./%(prog)s

  # Apply the fixes (insert blank lines where needed)
  ./%(prog)s --apply

  # Specify a target directory (defaults to parent directory of this script)
  ./%(prog)s /path/to/markdown/files --apply
"""
    )
    parser.add_argument(
        'target_dir',
        nargs='?',
        default=os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
        help='Target directory to scan (defaults to parent directory of this script)'
    )
    parser.add_argument(
        '--apply',
        action='store_true',
        help='Apply fixes in-place (default: dry-run only)'
    )
    parser.add_argument(
        '--version',
        action='version',
        version=f'%(prog)s {VERSION}'
    )

    args = parser.parse_args()

    dry_run = not args.apply
    target_dir = args.target_dir
        
    if not os.path.isdir(target_dir):
        print(f"{color('ERROR', Colors.RED + Colors.BOLD)} Target directory '{target_dir}' does not exist.")
        sys.exit(1)
        
    # Banner
    mode_str = color("Dry-run (Scan only)", Colors.YELLOW + Colors.BOLD) if dry_run else color("Apply (Fixing tables)", Colors.GREEN + Colors.BOLD)
    print(f"\n{color(f'✨ {parser.prog} v{VERSION} ✨', Colors.HEADER + Colors.BOLD)}")
    print(color("─" * 60, Colors.DIM))
    print(f"📂 {color('Target:', Colors.BOLD)} {target_dir}")
    print(f"⚙️  {color('Mode:',   Colors.BOLD)} {mode_str}")
    print(color("─" * 60, Colors.DIM) + "\n")
    
    modified_count = 0
    total_files_checked = 0
    
    for root, dirs, files in os.walk(target_dir):
        # Exclude hidden directories like .git
        dirs[:] = [d for d in dirs if not d.startswith('.')]
        for file in files:
            if file.endswith('.md'):
                total_files_checked += 1
                filepath = os.path.join(root, file)
                if process_file(filepath, dry_run=dry_run):
                    modified_count += 1
                    
    # Summary
    print(color("─" * 60, Colors.DIM))
    print(f"{color('SUMMARY', Colors.BOLD)}")
    print(color("─" * 60, Colors.DIM))
    print(f"  📁 Files checked:   {total_files_checked}")
    
    if dry_run:
        mod_color = Colors.YELLOW if modified_count > 0 else Colors.GREEN
        status_text = f"{modified_count} files require fixes" if modified_count > 0 else "All tables healthy!"
        print(f"  ⚠️  Broken files:   {color(str(modified_count), mod_color)}")
        print(f"  ⚙️  Status:         {color(status_text, mod_color)}")
        print(color("─" * 60, Colors.DIM))
        if modified_count > 0:
            print(f"\n👉 Run with {color('--apply', Colors.BOLD + Colors.GREEN)} to automatically apply all fixes:")
            print(f"   {color(sys.argv[0] + ' --apply', Colors.CYAN)}")
        else:
            print(f"\n{color('✨ Everything looks perfect! No action needed.', Colors.GREEN + Colors.BOLD)}")
    else:
        status_text = f"Successfully fixed {modified_count} files." if modified_count > 0 else "All tables healthy!"
        print(f"  ✅ Fixed files:     {color(str(modified_count), Colors.GREEN)}")
        print(f"  ⚙️  Status:         {color(status_text, Colors.GREEN)}")
        print(color("─" * 60, Colors.DIM))
        print(f"\n{color('✨ Done! All files have been successfully updated.', Colors.GREEN + Colors.BOLD)}")
    print()

if __name__ == '__main__':
    main()
