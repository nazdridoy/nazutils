def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description=(
            "Find remote static-asset links in Markdown files, download them\n"
            "locally, and rewrite the links to relative paths.\n\n"
            "Always shows a summary table first and asks for confirmation."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
ASSET DIRECTORY STRUCTURE
--------------------------
Directory target  →  per-file subfolders (default):
  Assets/
    Module-1-Networking-Today/   ← derived from the .md file stem
      2020-05-20_201301.jpg
      End-Devices.gif
    Module-2-Switch-Config/
      diagram.jpg

Single-file target  →  flat folder:
  Assets/
    image.jpg

Use --flat-assets to always use a single flat folder.

LINK FORMAT AFTER UPDATE
--------------------------
  ![](Assets/Module-1-Networking-Today/image.jpg)
  <!-- original: https://... -->

EXAMPLES
--------
  ./%(prog)s "CCNA_Sem_1/Module1.md"
  ./%(prog)s CCNA_Sem_1/
  ./%(prog)s CCNA_Sem_1/ --download-only
  ./%(prog)s CCNA_Sem_1/ --update-only
  ./%(prog)s CCNA_Sem_1/ --flat-assets
  ./%(prog)s CCNA_Sem_1/ --assets-dir media
  ./%(prog)s CCNA_Sem_1/ --strip-prefix "CCNA 1 v7.0 Curriculum "
  ./%(prog)s CCNA_Sem_1/ --force
  ./%(prog)s CCNA_Sem_1/ --yes
  ./%(prog)s CCNA_Sem_1/ --verbose

NOTES
-----
* When --strip-prefix is not provided, the full .md filename stem is used
  as the per-file asset subfolder name.
* When --strip-prefix TEXT is provided, that prefix is stripped from every
  stem before deriving the subfolder name.
* A .md.bak backup is created before any link rewrites.
* The script is idempotent: already-local links are never re-processed.
* Requires Python 3.8+. No pip install needed (stdlib only).
""",
    )
    parser.add_argument(
        "target",
        help="Path to a .md file OR a directory containing .md files (non-recursive).",
    )
    parser.add_argument(
        "--download-only", action="store_true",
        help="Download assets but do NOT modify the Markdown file.",
    )
    parser.add_argument(
        "--update-only", action="store_true",
        help="Rewrite links only (no downloading). Assets must already exist locally.",
    )
    parser.add_argument(
        "--assets-dir", default="Assets", metavar="NAME",
        help="Assets folder name (default: 'Assets'). Relative to target.",
    )
    parser.add_argument(
        "--flat-assets", action="store_true",
        help=(
            "Use a single flat assets folder instead of per-file subfolders "
            "(only relevant when target is a directory)."
        ),
    )
    parser.add_argument(
        "--strip-prefix", default=None, metavar="TEXT",
        help=(
            "Strip this prefix from .md stems when naming per-file asset subfolders. "
            "If omitted, the full .md stem is used as the subfolder name."
        ),
    )
    parser.add_argument(
        "--extensions",
        default=",".join(sorted(DEFAULT_EXTENSIONS)),
        metavar="EXT,...",
        help=(
            "Comma-separated extensions to treat as downloadable assets. "
            f"Default: {','.join(sorted(DEFAULT_EXTENSIONS))}"
        ),
    )
    parser.add_argument(
        "--force", action="store_true",
        help="Re-download assets even if they already exist locally.",
    )
    parser.add_argument(
        "--yes", "-y", action="store_true",
        help="Skip all confirmation prompts (good for scripting / CI).",
    )
    parser.add_argument(
        "--verbose", "-v", action="store_true",
        help="Print a line-by-line log of every action.",
    )
    parser.add_argument(
        "--restore", action="store_true",
        help=(
            "Restore .md.bak backup files, replacing the current .md files. "
            "Mutually exclusive with all other operation modes."
        ),
    )
    parser.add_argument(
        "--version", action="version", version=f"%(prog)s {VERSION}",
    )
    return parser


def main() -> None:
    parser = build_parser()
    args   = parser.parse_args()

    # Validate mutually exclusive flags
    if args.download_only and args.update_only:
        parser.error("--download-only and --update-only are mutually exclusive.")
    if args.restore and any([args.download_only, args.update_only,
                              args.flat_assets, args.force]):
        parser.error("--restore cannot be combined with other operation flags.")

    # --restore is a completely separate flow
    if args.restore:
        target = Path(args.target).expanduser().resolve()
        restore_backups(target, args.yes)
        sys.exit(0)

    mode = "full"
    if args.download_only:
        mode = "download-only"
    elif args.update_only:
        mode = "update-only"

    target        = Path(args.target).expanduser().resolve()
    allowed_exts  = {e.strip().lstrip(".").lower() for e in args.extensions.split(",")}
    is_single_file = target.is_file()

    # Collect files
    md_files = collect_md_files(target)
    if not md_files:
        print(_c("yellow", f"No .md files found in '{target}'."))
        sys.exit(0)

    # Assets root dir
    assets_root = target.parent / args.assets_dir if is_single_file else target / args.assets_dir

    # Per-file subdirectory logic (only for directory target)
    use_subdirs = not is_single_file and not args.flat_assets

    strip_prefix = ""
    if use_subdirs and args.strip_prefix:
        strip_prefix = args.strip_prefix

    # Print startup banner
    print(_c("bold", f"\n  {parser.prog} v{VERSION}"))
    print(_c("grey", f"  Target       : {target}"))
    print(_c("grey", f"  Mode         : {mode}"))
    print(_c("grey", f"  Assets root  : {assets_root}"))
    if use_subdirs:
        layout = "per-file subfolders"
        if strip_prefix:
            layout += f'  (strip prefix: "{strip_prefix}")'
        else:
            layout += "  (full stem as subfolder name)"
    else:
        layout = "flat"
    print(_c("grey", f"  Layout       : {layout}"))
    print(_c("grey", f"  Files        : {len(md_files)} markdown file(s)"))

    # Scan each file with its own assets_dir
    all_actions: list = []
    for md_file in md_files:
        if use_subdirs:
            subdir       = _stem_to_subdir(md_file.stem, strip_prefix)
            file_assets  = assets_root / subdir
        else:
            file_assets  = assets_root
        all_actions.extend(scan_file(md_file, file_assets, allowed_exts))

    if not all_actions:
        print(_c("yellow", "\n  No remote asset links found. Nothing to do."))
        sys.exit(0)

    # Group by file for preview and interactive modes
    by_file: dict = {}
    for a in all_actions:
        by_file.setdefault(a.md_file, []).append(a)

    # Preview + confirm → get approved list
    approved = _show_preview_menu(all_actions, by_file, mode, args.force, args.yes)

    # Execute
    execute(approved, mode, args.force, args.verbose)


if __name__ == "__main__":
    main()
